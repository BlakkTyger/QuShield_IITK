# QuShield Backend Configuration

# Application
APP_NAME=QuShield API
APP_VERSION=1.0.0
DEBUG=false

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./qushield.db
# DATABASE_URL=postgresql://user:password@localhost:5432/qushield

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Scan settings
SCAN_TIMEOUT=45
MAX_CONCURRENT_SCANS=5
OUTPUT_DIR=outputs
LOG_DIR=logs
